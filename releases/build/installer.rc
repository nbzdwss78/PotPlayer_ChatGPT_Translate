#include <windows.h>
#include <commctrl.h>
#include "resource.h"

IDI_INSTALLER_ICON ICON "..\\..\\icon.ico"
1 24 "installer.manifest"

IDR_LICENSE_TEXT       RCDATA "..\\..\\LICENSE"
IDR_WITH_CONTEXT_AS    RCDATA "..\\..\\SubtitleTranslate - ChatGPT.as"
IDR_WITH_CONTEXT_ICO   RCDATA "..\\..\\SubtitleTranslate - ChatGPT.ico"
